# Force LF line endings for all files that go into Docker containers
* text=auto eol=lf

# Windows-specific files that need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dump binary
*.pyc binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.m4a binary
*.mp3 binary
*.xlsx binary
*.zip binary
